'-Append'
echo ".venv/" >> .gitignore
echo "__pycache__/" >> .gitignore
echo "*.pyc" >> .gitignore'

# Checking Repository Status
'git status
git log
git log --oneline
git log --oneline -5'

# Staging Files
'git add .
git add readme.md
git add file1.py file2.py'

# Committing
'git commit -m "Your Commit"
git commit --amend
git commit --amend -m "New commit message"
git commit --amend --no-edit'

# Pushing & Pulling
'git push
git pull
git pull --rebase
